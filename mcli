#!/usr/bin/env bash
# mcli — manage custom services with Docker Compose
# https://github.com/milvasic/mcli

set -euo pipefail

VERSION="0.3.0"

# ── Help ──────────────────────────────────────────────────────────────────────
help() {
	colorize >&2 <<'EOF'
A single-file CLI for managing custom services with Docker Compose.

Usage: mcli <command> [service1 [service2 ...]] [--dry-run] [--all]

Commands:
  list                      # List discovered services (disabled services are marked)
  create-network            # Ensure the 'services' Docker bridge network exists
  start [services..]        # Start all or specified services (skips disabled)
  stop [services..]         # Stop all or specified services (skips disabled)
  restart [services..]      # Restart all or specified services (skips disabled)
  pull [services..]         # Pull latest images for all or specified services (skips disabled)
  disable <services..>      # Disable one or more services (excluded from start/stop/restart/pull)
  enable <services..>       # Re-enable one or more previously disabled services
  update                    # Update mcli to the latest version
  version, --version, -v    # Print version
  help, --help, -h          # Show this message

Options:
  --dry-run                 # Print commands that would be executed, but do not run them
                            #   (applicable to: create-network, start, stop, restart, pull, update)
                            #   (can appear anywhere after the command)
  --all                     # Include disabled services in start/stop/restart/pull
                            #   (applicable to: start, stop, restart, pull)
                            #   (can appear anywhere after the command)

Service discovery:
  - Each service is an immediate subfolder containing a docker compose file (docker-compose.yml or docker-compose.yaml)
  - Folders in .gitignore (simple literal prefix matching only), folders with a .git directory, and symlinks are skipped

Configuration:
  Disabled services are stored in ${XDG_CONFIG_HOME:-~/.config}/mcli/disabled

Usage example:
  mcli start                        # starts all enabled services by default
  mcli stop my-service --dry-run
  mcli disable my-service           # disables 'my-service' for future start/stop/pull commands
  mcli start --all                  # includes disabled services as well
EOF
	exit 1
}

# ── Colors & logging ──────────────────────────────────────────────────────────
if [ -t 1 ]; then
	RED=$'\033[0;31m'
	GREEN=$'\033[0;32m'
	YELLOW=$'\033[0;33m'
	CYAN=$'\033[0;36m'
	BOLD=$'\033[1m'
	RESET=$'\033[0m'
else
	RED=""
	GREEN=""
	YELLOW=""
	CYAN=""
	BOLD=""
	RESET=""
fi

log() { printf "\n${BOLD}=== %s ===${RESET}\n" "$1" >&2; }
dry_run_log() { printf "${YELLOW}[dry-run]${RESET} %s\n" "$1" >&2; }
error() { printf "${RED}ERROR:${RESET} %s\n" "$1" >&2; }
ok() { printf "${GREEN}%s${RESET}\n" "$1"; }

# ── Help colorizer ───────────────────────────────────────────────────────────
colorize_line() {
	sed \
		-e "s/\\(^\\|[^[:alnum:]_'-]\\)\\(mcli\\)\\([^[:alnum:]_'-]\\|$\\)/\\1${GREEN}\\2${RESET}\\3/g" \
		-e "s/\\(^\\|[^[:alnum:]_'-]\\)\\(list\\|create-network\\|start\\|stop\\|restart\\|pull\\|enable\\|disable\\|update\\|version\\|help\\)\\([^[:alnum:]_'-]\\|$\\)/\\1${YELLOW}\\2${RESET}\\3/g" \
		-e "s/--[a-z][a-z-]*/${CYAN}&${RESET}/g" \
		-e "s/\([ ,]\)\(-[a-z]\)/\\1${CYAN}\\2${RESET}/g"
}

colorize() {
	local line pre post
	while IFS= read -r line; do
		if [[ "$line" == *'#'* ]]; then
			pre="${line%%#*}"
			post="${line#*#}"
			pre="$(printf '%s' "$pre" | colorize_line)"
			printf '%s%s#%s%s\n' "$pre" "$GREEN" "$post" "$RESET"
		else
			printf '%s\n' "$line" | colorize_line
		fi
	done
}

# ── Configuration ─────────────────────────────────────────────────────────────
config_file() {
	echo "${XDG_CONFIG_HOME:-$HOME/.config}/mcli/disabled"
}

get_disabled_services() {
	local cf
	cf=$(config_file)
	[ -f "$cf" ] || return 0
	local prefix
	prefix="$(pwd)/"
	while IFS= read -r line; do
		[[ -z "$line" ]] && continue
		if [[ "$line" == "$prefix"* ]]; then
			echo "${line#"$prefix"}"
		fi
	done <"$cf"
}

is_service_disabled() {
	local service="$1"
	local cf
	cf=$(config_file)
	[ -f "$cf" ] || return 1
	grep -qxF "$(pwd)/$service" "$cf"
}

# ── Service discovery ─────────────────────────────────────────────────────────
get_services() {
	local services=()
	local gitignore=()
	if [ -f .gitignore ]; then
		mapfile -t gitignore < <(grep -v '^#' .gitignore | grep -v '^$' || true)
	fi
	shopt -s nullglob
	for dir in */; do
		# skip if not a directory
		[ -d "$dir" ] || continue
		# skip symlinks
		[ -L "$dir" ] && continue
		# skip .gitignore entries (simple literal prefix matching only; full gitignore glob syntax is not supported)
		for ignore in "${gitignore[@]}"; do
			[[ "$dir" == "$ignore"* ]] && continue 2
		done
		# skip if .git exists in the folder
		[ -d "$dir/.git" ] && continue
		# must have docker-compose.yml or docker-compose.yaml
		if [ -f "$dir/docker-compose.yml" ] || [ -f "$dir/docker-compose.yaml" ]; then
			services+=("${dir%/}")
		fi
	done
	shopt -u nullglob
	[[ ${#services[@]} -gt 0 ]] && printf '%s\n' "${services[@]}"
}

# Filter services by arguments (if any), excluding disabled services unless --all
filter_services() {
	local all_services=()
	mapfile -t all_services < <(get_services)
	local disabled_services=()
	mapfile -t disabled_services < <(get_disabled_services)

	local candidates=()
	if [ $# -eq 0 ]; then
		candidates=("${all_services[@]}")
	else
		local invalid=false
		for arg in "$@"; do
			local matched=false
			for svc in "${all_services[@]}"; do
				if [[ "$svc" == "$arg" ]]; then
					candidates+=("$svc")
					matched=true
				fi
			done
			if ! $matched; then
				error "Unknown service: ${CYAN}${arg}${RESET}"
				invalid=true
			fi
		done
		$invalid && return 1
	fi

	# Remove disabled services unless --all is set
	if $include_all || [ ${#disabled_services[@]} -eq 0 ]; then
		printf '%s\n' "${candidates[@]}"
	else
		for svc in "${candidates[@]}"; do
			local is_disabled=false
			for dsvc in "${disabled_services[@]}"; do
				if [[ "$svc" == "$dsvc" ]]; then
					is_disabled=true
					break
				fi
			done
			if $is_disabled; then
				if [ $# -gt 0 ]; then
					error "'${CYAN}${svc}${RESET}' is disabled (use ${CYAN}--all${RESET} to include it)"
				fi
			else
				echo "$svc"
			fi
		done
	fi
}

# ── List command ──────────────────────────────────────────────────────────────
list() {
	log "Discovered services:"
	local services=()
	mapfile -t services < <(get_services)
	if [[ ${#services[@]} -eq 0 ]]; then
		echo "  (none found)"
	else
		local enabled=() disabled=()
		for service in "${services[@]}"; do
			if is_service_disabled "$service"; then
				disabled+=("$service")
			else
				enabled+=("$service")
			fi
		done
		IFS=$'\n' read -r -d '' -a enabled < <(printf '%s\n' "${enabled[@]}" | sort && printf '\0') || true
		IFS=$'\n' read -r -d '' -a disabled < <(printf '%s\n' "${disabled[@]}" | sort && printf '\0') || true
		for service in "${enabled[@]}"; do
			printf "  ${CYAN}%s${RESET}\n" "$service"
		done
		for service in "${disabled[@]}"; do
			printf "  ${CYAN}%s${RESET} ${YELLOW}(disabled)${RESET}\n" "$service"
		done
	fi
}

# ── Core commands ───────────────────────────────────────────────────────────────────
create_network() {
	log "Ensuring Docker network 'services' exists"
	if $dry_run; then
		dry_run_log "docker network inspect services || docker network create --driver bridge services"
	elif docker network inspect services >/dev/null 2>&1; then
		log "Network 'services' already exists"
	else
		docker network create --driver bridge services
	fi
}

start() {
	local services=()
	local services_output
	services_output=$(filter_services "$@") || return 1
	[[ -n "$services_output" ]] && mapfile -t services <<<"$services_output"
	local failed=()
	for service in "${services[@]}"; do
		log "Starting ${CYAN}${service}${RESET}"
		local cmd
		cmd="docker compose --project-directory \"$service\" up -d"
		if $dry_run; then
			dry_run_log "$cmd"
		else
			if ! eval "$cmd"; then
				error "${CYAN}${service}${RESET} start failed"
				failed+=("$service")
			fi
		fi
	done
	if [ ${#failed[@]} -gt 0 ]; then
		error "The following services failed to start: ${CYAN}${failed[*]}${RESET}"
		return 1
	fi
}

stop() {
	local services=()
	local services_output
	services_output=$(filter_services "$@") || return 1
	[[ -n "$services_output" ]] && mapfile -t services <<<"$services_output"
	local failed=()
	for service in "${services[@]}"; do
		log "Stopping ${CYAN}${service}${RESET}"
		local cmd
		cmd="docker compose --project-directory \"$service\" down --remove-orphans"
		if $dry_run; then
			dry_run_log "$cmd"
		else
			if ! eval "$cmd"; then
				error "${CYAN}${service}${RESET} stop failed"
				failed+=("$service")
			fi
		fi
	done
	if [ ${#failed[@]} -gt 0 ]; then
		error "The following services failed to stop: ${CYAN}${failed[*]}${RESET}"
		return 1
	fi
}

restart() {
	stop "$@" || return 1
	start "$@"
}

# ── Disable / Enable commands ──────────────────────────────────────────────────────
enable() {
	if [ $# -eq 0 ]; then
		error "Usage: mcli enable <service1> [service2 ...]"
		return 1
	fi
	local all_services=()
	mapfile -t all_services < <(get_services)
	local invalid=false
	for arg in "$@"; do
		local matched=false
		for svc in "${all_services[@]}"; do
			[[ "$svc" == "$arg" ]] && matched=true && break
		done
		if ! $matched; then
			error "Unknown service: ${CYAN}${arg}${RESET}"
			invalid=true
		fi
	done
	$invalid && return 1

	local cf
	cf=$(config_file)
	for arg in "$@"; do
		local entry
		entry="$(pwd)/$arg"
		if [ -f "$cf" ] && grep -qxF "$entry" "$cf"; then
			local tmp
			tmp=$(grep -vxF "$entry" "$cf" || true)
			printf '%s\n' "$tmp" >"$cf"
			# Remove trailing empty lines left by printf on empty content
			if [ ! -s "$cf" ] || [ -z "$(tr -d '[:space:]' <"$cf")" ]; then
				>"$cf"
			fi
			ok "${CYAN}${arg}${RESET} enabled"
		else
			ok "${CYAN}${arg}${RESET} is already enabled"
		fi
	done
}

disable() {
	if [ $# -eq 0 ]; then
		error "Usage: mcli disable <service1> [service2 ...]"
		return 1
	fi
	local all_services=()
	mapfile -t all_services < <(get_services)
	local invalid=false
	for arg in "$@"; do
		local matched=false
		for svc in "${all_services[@]}"; do
			[[ "$svc" == "$arg" ]] && matched=true && break
		done
		if ! $matched; then
			error "Unknown service: ${CYAN}${arg}${RESET}"
			invalid=true
		fi
	done
	$invalid && return 1

	local cf
	cf=$(config_file)
	mkdir -p "$(dirname "$cf")"
	touch "$cf"
	for arg in "$@"; do
		local entry
		entry="$(pwd)/$arg"
		if grep -qxF "$entry" "$cf"; then
			ok "${CYAN}${arg}${RESET} is already disabled"
		else
			echo "$entry" >>"$cf"
			ok "${CYAN}${arg}${RESET} disabled"
		fi
	done
}

pull() {
	local services=()
	local services_output
	services_output=$(filter_services "$@") || return 1
	[[ -n "$services_output" ]] && mapfile -t services <<<"$services_output"
	local failed=()
	for service in "${services[@]}"; do
		log "Pulling images for ${CYAN}${service}${RESET} (skipping buildable services)"
		local cmd
		cmd="docker compose --project-directory \"$service\" pull --ignore-buildable"
		if $dry_run; then
			dry_run_log "$cmd"
		else
			if ! eval "$cmd"; then
				error "${CYAN}${service}${RESET} pull failed"
				failed+=("$service")
			fi
		fi
	done
	if [ ${#failed[@]} -gt 0 ]; then
		error "The following services failed to pull: ${CYAN}${failed[*]}${RESET}"
		return 1
	fi
}

# ── Update command ────────────────────────────────────────────────────────────
INSTALLER_SELF_URL="https://raw.githubusercontent.com/milvasic/mcli/refs/heads/main/install.sh"
update() {
	if $dry_run; then
		dry_run_log "sh -c \"\$(curl -fsSL \"${INSTALLER_SELF_URL}\")\""
		return
	fi
	if command -v curl >/dev/null 2>&1; then
		sh -c "$(curl -fsSL "${INSTALLER_SELF_URL}")" -- --yes
	elif command -v wget >/dev/null 2>&1; then
		sh -c "$(wget -qO- "${INSTALLER_SELF_URL}")" -- --yes
	else
		error "Neither curl nor wget found. Please install one and try again."
		exit 1
	fi
}

# ── Main dispatch ─────────────────────────────────────────────────────────────────
COMMAND="${1:-}"
[ $# -ge 1 ] && shift

# parse options, collect service names after options
service_args=()
while [[ $# -gt 0 ]]; do
	case "$1" in
	--dry-run)
		dry_run=true
		shift
		;;
	--all)
		include_all=true
		shift
		;;
	-*)
		error "Unknown option: $1"
		exit 1
		;;
	*)
		service_args+=("$1")
		shift
		;;
	esac
done

case "${COMMAND}" in
list) list ;;
create-network) create_network ;;
start) start "${service_args[@]}" ;;
stop) stop "${service_args[@]}" ;;
restart) restart "${service_args[@]}" ;;
pull) pull "${service_args[@]}" ;;
enable) enable "${service_args[@]}" ;;
disable) disable "${service_args[@]}" ;;
update) update ;;
version | --version | -v) echo "$VERSION" ;;
help | --help | -h) help ;;
*)
	error "Unknown command: ${COMMAND}"
	help
	;;
esac
